---
import Base from "../layouts/Base.astro";
import ToolCard from "../components/ui/ToolCard.astro";
import { categories } from "../data/categories";
import { getFeaturedTools, tools } from "../data/tools";

const featuredTools = getFeaturedTools();
---

<Base title="Every Tool You Need. Zero Uploads.">
  {/* Hero Section */}
  <section class="relative overflow-hidden">
    {/* Yellow glow effect */}
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-primary/5 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-16 sm:pt-24 pb-16 text-center relative">
      {/* Badge */}
      <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-surface-card border border-hairline rounded-full text-caption text-muted mb-8">
        <span class="inline-block w-2 h-2 rounded-full bg-accent-emerald"></span>
        {tools.length} tools live — 100% client-side
      </div>

      {/* Heading */}
      <h1 class="text-display-md sm:text-display-lg lg:text-display-xl mb-6 max-w-4xl mx-auto">
        Every Tool You Need.<br />
        <span class="text-primary">Zero Uploads.</span>
      </h1>

      {/* Subheading */}
      <p class="text-body-md sm:text-title-md text-muted max-w-2xl mx-auto mb-8">
        {tools.length} privacy-first tools for PDF, images, text, code & more.<br class="hidden sm:block" />
        Runs in your browser. No accounts. No limits.
      </p>

      {/* CTA Buttons */}
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="#categories" class="btn-primary no-underline">
          Browse All {tools.length} Tools
        </a>
        <a href="#featured" class="btn-secondary no-underline">
          See Featured Tools
        </a>
      </div>

      {/* Stats */}
      <div class="flex items-center justify-center gap-8 sm:gap-16 mt-12 pt-8 border-t border-hairline">
        <div class="text-center">
          <div class="text-display-sm text-primary">{tools.length}+</div>
          <div class="text-caption text-muted mt-1">Free Tools</div>
        </div>
        <div class="text-center">
          <div class="text-display-sm text-primary">{categories.length}</div>
          <div class="text-caption text-muted mt-1">Categories</div>
        </div>
        <div class="text-center">
          <div class="text-display-sm text-primary">0</div>
          <div class="text-caption text-muted mt-1">Uploads</div>
        </div>
      </div>
    </div>
  </section>

  {/* Featured Tools */}
  <section id="featured" class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-title-lg text-on-dark">Most Popular</h2>
        <p class="text-body-sm text-muted mt-1">The tools people use most</p>
      </div>
      <a href="#categories" class="text-body-sm text-primary hover:text-primary-active transition-colors no-underline">
        All tools →
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {featuredTools.map((tool) => (
        <ToolCard tool={tool} />
      ))}
    </div>
  </section>

  {/* Categories */}
  <section id="categories" class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
    <h2 class="text-title-lg text-on-dark mb-2">Browse by Category</h2>
    <p class="text-body-sm text-muted mb-8">Find the right tool for the job</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {categories.map((cat) => (
        <a
          href={`/${cat.id}`}
          class="block bg-surface-card border border-hairline rounded-lg p-6 transition-all duration-200 hover:border-hairline-strong hover:-translate-y-0.5 group no-underline"
        >
          <div class="flex items-center gap-3 mb-3">
            <div
              class="w-10 h-10 rounded-lg flex items-center justify-center"
              style={`background-color: ${cat.color}15; color: ${cat.color}`}
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
              </svg>
            </div>
            <h3 class="text-title-sm text-on-dark group-hover:text-primary transition-colors">{cat.name}</h3>
          </div>
          <p class="text-body-sm text-muted">{cat.description}</p>
        </a>
      ))}
    </div>
  </section>

  {/* Why Section */}
  <section class="bg-surface-soft border-y border-hairline">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
      <h2 class="text-title-lg text-on-dark text-center mb-12">Why ToolBundle?</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {/* Privacy */}
        <div class="text-center">
          <div class="w-12 h-12 rounded-lg bg-accent-emerald/10 text-accent-emerald flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3 class="text-title-sm text-on-dark mb-2">Mathematically Private</h3>
          <p class="text-body-sm text-muted">Your files never leave your browser. Every tool processes data locally. No uploads, no servers.</p>
        </div>

        {/* Speed */}
        <div class="text-center">
          <div class="w-12 h-12 rounded-lg bg-accent-blue/10 text-accent-blue flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
          </div>
          <h3 class="text-title-sm text-on-dark mb-2">Instant Results</h3>
          <p class="text-body-sm text-muted">No upload waits, no queues. Results appear instantly because everything runs on your machine.</p>
        </div>

        {/* Free */}
        <div class="text-center">
          <div class="w-12 h-12 rounded-lg bg-primary/10 text-primary flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          </div>
          <h3 class="text-title-sm text-on-dark mb-2">Free Forever</h3>
          <p class="text-body-sm text-muted">No accounts, no subscriptions, no paywalls. Every tool stays free for everyone.</p>
        </div>
      </div>
    </div>
  </section>
</Base>
