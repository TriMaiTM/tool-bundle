---
import Base from "../../layouts/Base.astro";
import ToolCard from "../../components/ui/ToolCard.astro";
import { categories, getCategoryById } from "../../data/categories";
import { getToolsByCategory } from "../../data/tools";
import { generateBreadcrumbSchema, generateCollectionPageSchema } from "../../utils/seo";

export function getStaticPaths() {
	return categories.map((cat) => ({
		params: { category: cat.id },
	}));
}

const SITE_URL = "https://toolbundle.app";

const { category } = Astro.params;
const cat = getCategoryById(category!);
if (!cat) return Astro.redirect("/");

const categoryTools = getToolsByCategory(category!);
const categoryUrl = `${SITE_URL}/${category}`;
const toolNames = categoryTools.map((t) => t.name);

const collectionSchema = generateCollectionPageSchema(
	cat.name,
	cat.description,
	toolNames,
	categoryUrl,
);

const breadcrumbSchema = generateBreadcrumbSchema([
	{ name: "Home", url: SITE_URL },
	{ name: cat.name, url: categoryUrl },
]);
---

<Base title={`${cat.name} — Free Online Tools`} description={cat.description} canonicalUrl={categoryUrl}>
  {/* Category JSON-LD */}
  <script type="application/ld+json" set:html={collectionSchema} />
  <script type="application/ld+json" set:html={breadcrumbSchema} />
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
    {/* Breadcrumb */}
    <nav class="flex items-center gap-2 text-caption mb-8">
      <a href="/" class="hover:text-on-dark transition-colors">Home</a>
      <span class="text-muted-soft">/</span>
      <span class="text-on-dark">{cat.name}</span>
    </nav>

    {/* Category Header */}
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <div
          class="w-12 h-12 rounded-lg flex items-center justify-center"
          style={`background-color: ${cat.color}15; color: ${cat.color}`}
        >
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
          </svg>
        </div>
        <div>
          <h1 class="text-display-sm">{cat.name}</h1>
        </div>
      </div>
      <p class="text-body-md text-muted max-w-2xl">{cat.description}</p>
      <div class="flex items-center gap-2 mt-4 text-caption text-muted">
        <span class="inline-block w-2 h-2 rounded-full bg-accent-emerald"></span>
        {categoryTools.length} tools — all 100% client-side
      </div>
    </header>

    {/* Tools Grid */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {categoryTools.map((tool) => (
        <ToolCard tool={tool} />
      ))}
    </div>
  </div>
</Base>
