---
import { categories } from "../../data/categories";
---

<footer class="bg-surface-soft border-t border-hairline mt-16" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      {/* Brand */}
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="text-xl font-bold text-on-dark tracking-tight no-underline">
          Tool<span class="text-primary">Bundle</span>
        </a>
        <p class="text-body-sm text-muted mt-3 max-w-xs">
          Free, privacy-first tools that run 100% in your browser. No uploads. No accounts. No limits.
        </p>
        <div class="flex items-center gap-2 mt-4 text-caption text-muted">
          <span class="inline-block w-2 h-2 rounded-full bg-accent-emerald"></span>
          Your files never leave your browser
        </div>
      </div>

      {/* Categories */}
      <nav aria-label="Category links">
        <h3 class="text-caption-uppercase text-on-dark mb-4">Categories</h3>
        <ul class="space-y-2">
          {categories.map((cat) => (
            <li>
              <a href={`/${cat.id}`} class="text-body-sm text-muted hover:text-on-dark transition-colors no-underline">
                {cat.name}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      {/* Popular Tools */}
      <nav aria-label="Popular tools">
        <h3 class="text-caption-uppercase text-on-dark mb-4">Popular Tools</h3>
        <ul class="space-y-2">
          <li><a href="/image/png-to-jpg" class="text-body-sm text-muted hover:text-on-dark transition-colors no-underline">PNG to JPG</a></li>
          <li><a href="/image/image-resizer" class="text-body-sm text-muted hover:text-on-dark transition-colors no-underline">Image Resizer</a></li>
          <li><a href="/developer/json-formatter" class="text-body-sm text-muted hover:text-on-dark transition-colors no-underline">JSON Formatter</a></li>
          <li><a href="/text/word-counter" class="text-body-sm text-muted hover:text-on-dark transition-colors no-underline">Word Counter</a></li>
          <li><a href="/developer/base64-encoder" class="text-body-sm text-muted hover:text-on-dark transition-colors no-underline">Base64 Encoder</a></li>
        </ul>
      </nav>

      {/* Info */}
      <nav aria-label="Information links">
        <h3 class="text-caption-uppercase text-on-dark mb-4">Info</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-body-sm text-muted hover:text-on-dark transition-colors no-underline">About</a></li>
          <li><a href="/" class="text-body-sm text-muted hover:text-on-dark transition-colors no-underline">Privacy Policy</a></li>
          <li><a href="/" class="text-body-sm text-muted hover:text-on-dark transition-colors no-underline">Terms of Service</a></li>
        </ul>
      </nav>
    </div>

    {/* Bottom bar */}
    <div class="mt-12 pt-6 border-t border-hairline flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-caption text-muted-soft">
        © {new Date().getFullYear()} ToolBundle. All rights reserved.
      </p>
      <p class="text-caption text-muted-soft flex items-center gap-2">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-accent-emerald"></span>
        Built with Astro • 100% client-side
      </p>
    </div>
  </div>
</footer>
