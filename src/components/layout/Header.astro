---
import { categories } from "../../data/categories";
import { tools } from "../../data/tools";
import SearchModal from "../ui/SearchModal";
---

<header class="sticky top-0 z-50 bg-canvas/95 backdrop-blur-sm border-b border-hairline">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    {/* Logo */}
    <a href="/" class="flex items-center gap-2 no-underline">
      <span class="text-xl font-bold text-on-dark tracking-tight">
        Tool<span class="text-primary">Bundle</span>
      </span>
    </a>

    {/* Desktop Nav */}
    <nav class="hidden md:flex items-center gap-6">
      <a href="/" class="text-nav-link text-muted hover:text-on-dark transition-colors">Home</a>
      <div class="relative group">
        <button class="text-nav-link text-muted hover:text-on-dark transition-colors flex items-center gap-1">
          Categories
          <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M2 4l4 4 4-4"/>
          </svg>
        </button>
        {/* Dropdown */}
        <div class="absolute top-full left-0 mt-2 w-56 bg-surface-card border border-hairline rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2">
          {categories.map((cat) => (
            <a
              href={`/${cat.id}`}
              class="flex items-center gap-3 px-4 py-2.5 text-body-sm text-body hover:text-on-dark hover:bg-surface-elevated transition-colors no-underline"
            >
              <span class="w-2 h-2 rounded-full" style={`background-color: ${cat.color}`}></span>
              {cat.name}
            </a>
          ))}
        </div>
      </div>
    </nav>

    {/* Search + Mobile menu */}
    <div class="flex items-center gap-3">
      <SearchModal client:load tools={tools} categories={categories} />

      {/* Mobile menu toggle */}
      <button id="mobile-menu-toggle" class="md:hidden p-2 text-muted hover:text-on-dark">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  {/* Mobile Menu */}
  <div id="mobile-menu" class="hidden md:hidden bg-surface-card border-t border-hairline">
    <nav class="px-4 py-4 space-y-1">
      <a href="/" class="block px-3 py-2 text-body-sm text-body hover:text-on-dark hover:bg-surface-elevated rounded-md transition-colors">Home</a>
      {categories.map((cat) => (
        <a
          href={`/${cat.id}`}
          class="flex items-center gap-3 px-3 py-2 text-body-sm text-body hover:text-on-dark hover:bg-surface-elevated rounded-md transition-colors"
        >
          <span class="w-2 h-2 rounded-full" style={`background-color: ${cat.color}`}></span>
          {cat.name}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
