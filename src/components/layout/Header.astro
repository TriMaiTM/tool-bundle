---
import { categories } from "../../data/categories";
import { tools } from "../../data/tools";
import SearchModal from "../ui/SearchModal";
---

<a href="#main-content" class="skip-to-content">Skip to content</a>

<header class="sticky top-0 z-50 bg-canvas/95 backdrop-blur-sm border-b border-hairline" role="banner">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    {/* Logo */}
    <a href="/" class="flex items-center gap-2 no-underline" aria-label="ToolBundle: Home">
      <span class="text-xl font-bold text-ink tracking-tight">
        Tool<span class="text-primary">Bundle</span>
      </span>
    </a>

    {/* Desktop Nav */}
    <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
      <a href="/" class="text-nav-link text-muted hover:text-ink transition-colors">Home</a>
      <a href="/blog" class="text-nav-link text-muted hover:text-ink transition-colors">Blog</a>
      <a href="/workflow" class="text-nav-link text-muted hover:text-ink transition-colors">Workflow</a>
      <div class="relative group">
        <button
          class="text-nav-link text-muted hover:text-ink transition-colors flex items-center gap-1"
          aria-haspopup="true"
          aria-expanded="false"
        >
          Categories
          <svg class="w-3 h-3" aria-hidden="true" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M2 4l4 4 4-4"/>
          </svg>
        </button>
        {/* Dropdown */}
        <div
          class="absolute top-full left-0 mt-2 w-56 bg-surface-card border border-hairline rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2"
          role="menu"
          aria-label="Categories"
        >
          {categories.map((cat) => (
            <a
              href={`/${cat.id}`}
              class="flex items-center gap-3 px-4 py-2.5 text-body-sm text-body hover:text-ink hover:bg-surface-elevated transition-colors no-underline"
              role="menuitem"
            >
              <span class="w-2 h-2 rounded-full" style={`background-color: ${cat.color}`} aria-hidden="true"></span>
              {cat.name}
            </a>
          ))}
        </div>
      </div>
    </nav>

    {/* Search + Mobile menu */}
    <div class="flex items-center gap-3">
      <SearchModal client:load tools={tools} categories={categories} />

      {/* Changelog Link with Tooltip */}
      <div class="relative group">
        <a
          href="/changelog"
          class="p-2 text-muted hover:text-ink transition-colors cursor-pointer rounded-lg hover:bg-surface-card flex items-center justify-center"
          aria-label="Changelog"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </a>
        <span class="absolute top-full left-1/2 -translate-x-1/2 mt-2 bg-charcoal text-on-dark text-[11px] px-2.5 py-1.5 rounded-lg opacity-0 pointer-events-none group-hover:opacity-100 transition-all duration-150 shadow-md whitespace-nowrap z-50 transform translate-y-1 group-hover:translate-y-0">
          Changelog
        </span>
      </div>

      {/* Settings Link with Tooltip */}
      <div class="relative group">
        <a
          href="/settings"
          class="p-2 text-muted hover:text-ink transition-colors cursor-pointer rounded-lg hover:bg-surface-card flex items-center justify-center"
          aria-label="Settings"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.43l-1.003.828c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.43l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          </svg>
        </a>
        <span class="absolute top-full left-1/2 -translate-x-1/2 mt-2 bg-charcoal text-on-dark text-[11px] px-2.5 py-1.5 rounded-lg opacity-0 pointer-events-none group-hover:opacity-100 transition-all duration-150 shadow-md whitespace-nowrap z-50 transform translate-y-1 group-hover:translate-y-0">
          Settings
        </span>
      </div>

      {/* Mobile menu toggle */}
      <button
        id="mobile-menu-toggle"
        class="md:hidden p-2 text-muted hover:text-ink"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-5 h-5" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  {/* Mobile Menu */}
  <div id="mobile-menu" class="hidden md:hidden bg-surface-card border-t border-hairline" role="navigation" aria-label="Mobile navigation">
    <nav class="px-4 py-4 space-y-1">
      <a href="/" class="block px-3 py-2 text-body-sm text-body hover:text-ink hover:bg-surface-elevated rounded-md transition-colors">Home</a>
      <a href="/blog" class="block px-3 py-2 text-body-sm text-body hover:text-ink hover:bg-surface-elevated rounded-md transition-colors">Blog</a>
      <a href="/workflow" class="block px-3 py-2 text-body-sm text-body hover:text-ink hover:bg-surface-elevated rounded-md transition-colors">Workflow</a>
      {categories.map((cat) => (
        <a
          href={`/${cat.id}`}
          class="flex items-center gap-3 px-3 py-2 text-body-sm text-body hover:text-ink hover:bg-surface-elevated rounded-md transition-colors"
        >
          <span class="w-2 h-2 rounded-full" style={`background-color: ${cat.color}`}></span>
          {cat.name}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  // 1. Mobile menu toggle
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    toggle?.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
