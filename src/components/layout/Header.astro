---
import { categories } from "../../data/categories";
import { tools } from "../../data/tools";
import SearchModal from "../ui/SearchModal";
---

<a href="#main-content" class="skip-to-content">Skip to content</a>

<header class="sticky top-0 z-50 bg-canvas/95 backdrop-blur-sm border-b border-hairline" role="banner">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    {/* Logo */}
    <a href="/" class="flex items-center gap-2 no-underline" aria-label="ToolBundle — Home">
      <span class="text-xl font-bold text-on-dark tracking-tight">
        Tool<span class="text-primary">Bundle</span>
      </span>
    </a>

    {/* Desktop Nav */}
    <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
      <a href="/" class="text-nav-link text-muted hover:text-on-dark transition-colors">Home</a>
      <a href="/blog" class="text-nav-link text-muted hover:text-on-dark transition-colors">Blog</a>
      <a href="/developer/workflow-builder" class="text-nav-link text-muted hover:text-on-dark transition-colors">Workflow</a>
      <div class="relative group">
        <button
          class="text-nav-link text-muted hover:text-on-dark transition-colors flex items-center gap-1"
          aria-haspopup="true"
          aria-expanded="false"
        >
          Categories
          <svg class="w-3 h-3" aria-hidden="true" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M2 4l4 4 4-4"/>
          </svg>
        </button>
        {/* Dropdown */}
        <div
          class="absolute top-full left-0 mt-2 w-56 bg-surface-card border border-hairline rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2"
          role="menu"
          aria-label="Categories"
        >
          {categories.map((cat) => (
            <a
              href={`/${cat.id}`}
              class="flex items-center gap-3 px-4 py-2.5 text-body-sm text-body hover:text-on-dark hover:bg-surface-elevated transition-colors no-underline"
              role="menuitem"
            >
              <span class="w-2 h-2 rounded-full" style={`background-color: ${cat.color}`} aria-hidden="true"></span>
              {cat.name}
            </a>
          ))}
        </div>
      </div>
    </nav>

    {/* Search + Mobile menu */}
    <div class="flex items-center gap-3">
      <SearchModal client:load tools={tools} categories={categories} />

      {/* Theme Toggle */}
      <button
        id="theme-toggle"
        class="p-2 text-muted hover:text-on-dark transition-colors"
        aria-label="Toggle dark mode"
      >
        {/* Sun icon (shown in dark mode) */}
        <svg class="w-5 h-5 hidden dark:block" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        {/* Moon icon (shown in light mode) */}
        <svg class="w-5 h-5 block dark:hidden" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      {/* Mobile menu toggle */}
      <button
        id="mobile-menu-toggle"
        class="md:hidden p-2 text-muted hover:text-on-dark"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-5 h-5" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  {/* Mobile Menu */}
  <div id="mobile-menu" class="hidden md:hidden bg-surface-card border-t border-hairline" role="navigation" aria-label="Mobile navigation">
    <nav class="px-4 py-4 space-y-1">
      <a href="/" class="block px-3 py-2 text-body-sm text-body hover:text-on-dark hover:bg-surface-elevated rounded-md transition-colors">Home</a>
      <a href="/blog" class="block px-3 py-2 text-body-sm text-body hover:text-on-dark hover:bg-surface-elevated rounded-md transition-colors">Blog</a>
      <a href="/developer/workflow-builder" class="block px-3 py-2 text-body-sm text-body hover:text-on-dark hover:bg-surface-elevated rounded-md transition-colors">Workflow</a>
      {categories.map((cat) => (
        <a
          href={`/${cat.id}`}
          class="flex items-center gap-3 px-3 py-2 text-body-sm text-body hover:text-on-dark hover:bg-surface-elevated rounded-md transition-colors"
        >
          <span class="w-2 h-2 rounded-full" style={`background-color: ${cat.color}`}></span>
          {cat.name}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  // Theme toggle
  const themeToggle = document.getElementById("theme-toggle");
  themeToggle?.addEventListener("click", () => {
    const current = document.documentElement.getAttribute("data-theme");
    const next = current === "dark" ? "light" : "dark";
    document.documentElement.setAttribute("data-theme", next);
    try { localStorage.setItem("toolbundle_theme", next); } catch {}
    // Update meta theme-color
    const meta = document.querySelector('meta[name="theme-color"]');
    if (meta) meta.setAttribute("content", next === "dark" ? "#161310" : "#ffffff");
  });

  // Mobile menu toggle
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    toggle?.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
