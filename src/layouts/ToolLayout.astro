---
import Base from "./Base.astro";
import { getCategoryById } from "../data/categories";
import { generateBreadcrumbSchema, generateToolSchema } from "../utils/seo";
import FavoriteButton from "../components/ui/FavoriteButton";
import CollectionPicker from "../components/ui/CollectionPicker";

const SITE_URL = "https://toolbundle.app";

interface Props {
	title: string;
	description: string;
	category: string;
	toolId: string;
}

const { title, description, category, toolId } = Astro.props;
const cat = getCategoryById(category);

const toolUrl = `${SITE_URL}${Astro.url.pathname}`;
const categoryName = cat?.name || "Tools";
const categorySlug = category;

const toolSchema = generateToolSchema(title, description, toolUrl, categoryName, categorySlug);

const breadcrumbSchema = generateBreadcrumbSchema([
	{ name: "Home", url: SITE_URL },
	{ name: categoryName, url: `${SITE_URL}/${categorySlug}` },
	{ name: title, url: toolUrl },
]);
---

<Base title={title} description={description} canonicalUrl={toolUrl}>
  {/* Tool JSON-LD */}
  <script type="application/ld+json" set:html={toolSchema} />
  <script type="application/ld+json" set:html={breadcrumbSchema} />
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
    {/* Breadcrumb */}
    <nav class="flex items-center gap-2 text-caption mb-8">
      <a href="/" class="hover:text-on-dark transition-colors">Home</a>
      <span class="text-muted-soft">/</span>
      {cat && (
        <>
          <a href={`/${cat.id}`} class="hover:text-on-dark transition-colors">{cat.name}</a>
          <span class="text-muted-soft">/</span>
        </>
      )}
      <span class="text-on-dark">{title}</span>
    </nav>

    {/* Tool Header */}
    <header class="mb-8">
      {cat && (
        <span class="badge mb-3" style="color: #000000;">
          {cat.name}
        </span>
      )}
      <div class="flex items-center gap-3 mb-3">
        <h1 class="text-display-sm">{title}</h1>
        <FavoriteButton toolId={toolId} client:load />
        <CollectionPicker toolId={toolId} client:only="preact" />
      </div>
      <p class="text-body-md text-muted max-w-2xl">{description}</p>
    </header>

    {/* Privacy Badge */}
    <div class="flex items-center gap-2 mb-8 text-caption">
      <span class="inline-block w-2 h-2 rounded-full bg-accent-emerald"></span>
      <span>100% client-side — your files never leave your browser</span>
    </div>

    {/* Tool Content */}
    <div class="card">
      <slot />
    </div>
  </div>

  <script define:vars={{ toolId, category }}>
    // Track tool visit history
    try {
      const key = "toolbundle_history";
      const history = JSON.parse(localStorage.getItem(key) || "[]");
      const filtered = history.filter(function(h) { return h.toolId !== toolId; });
      filtered.unshift({ toolId: toolId, visitedAt: Date.now(), path: "/" + category + "/" });
      localStorage.setItem(key, JSON.stringify(filtered.slice(0, 30)));
    } catch {}

    // Track tool usage analytics
    try {
      const aKey = "toolbundle_analytics";
      const aRaw = localStorage.getItem(aKey);
      const aData = aRaw ? JSON.parse(aRaw) : { pageViews: [], toolEvents: [], sessions: 0, firstVisit: Date.now(), lastVisit: Date.now() };
      aData.toolEvents.push({
        toolId: toolId,
        category: category,
        action: "view",
        timestamp: Date.now(),
      });
      if (aData.toolEvents.length > 1000) aData.toolEvents = aData.toolEvents.slice(-1000);
      aData.lastVisit = Date.now();
      localStorage.setItem(aKey, JSON.stringify(aData));
    } catch {}
  </script>
</Base>
