{
  "name": "toolbundle",
  "type": "module",
  "version": "0.1.0",
  "description": "A collection of free, privacy-first browser tools",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "test": "vitest run",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/preact": "^4.0.8",
    "@astrojs/sitemap": "3.7.2",
    "@huggingface/transformers": "3.8.1",
    "@tailwindcss/vite": "^4.1.4",
    "astro": "^5.7.10",
    "fuse.js": "7.3.0",
    "js-yaml": "^4.1.0",
    "jsbarcode": "3.12.3",
    "lucide": "^0.503.0",
    "marked": "18.0.3",
    "pdf-lib": "^1.17.1",
    "preact": "^10.26.6",
    "qrcode": "1.5.4",
    "tailwindcss": "^4.1.4",
    "tesseract.js": "5.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,css,md}": [
      "biome format --write",
      "biome check --fix"
    ],
    "*.astro": [
      "biome format --write"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/js-yaml": "^4.0.9",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "16.4.0",
    "sharp": "0.34.5",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
