{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["ES2017", "ES2018", "ES2019", "ES2020", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@tools/*": ["src/tools/*"],
      "@data/*": ["src/data/*"],
      "@utils/*": ["src/utils/*"],
      "@styles/*": ["src/styles/*"],
    },
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"],
}
